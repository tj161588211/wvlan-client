<Window x:Class="WVLAN.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WVLAN.Client"
        xmlns:vm="clr-namespace:WVLAN.Client.ViewModels"
        xmlns:views="clr-namespace:WVLAN.Client.Views"
        mc:Ignorable="d"
        Title="WVLAN Client - Windows Virtual LAN" 
        Height="700" Width="1200"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationBackground}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" 
                Background="{DynamicResource NavigationBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 应用标题 -->
                <StackPanel Grid.Row="0" Margin="20,20,20,10">
                    <TextBlock Text="WVLAN" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock Text="Virtual LAN Client" 
                               FontSize="12" 
                               Opacity="0.7"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- 导航菜单 -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigation}"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15,12" 
                                    CornerRadius="8"
                                    Margin="10,4"
                                    Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" 
                                               FontSize="18" 
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" 
                                               VerticalAlignment="Center"
                                               FontWeight="{Binding IsSelected, Converter={StaticResource FontWeightConverter}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 底部状态 -->
                <StackPanel Grid.Row="2" Margin="20,10">
                    <Border Padding="15,12" 
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Connection Status" 
                                       FontSize="11" 
                                       Opacity="0.7"/>
<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
<Ellipse Width="10" Height="10" 
Fill="{Binding ConnectionStatusColor}"
Margin="0,0,8,0"/>
<TextBlock Text="{Binding ConnectionStatusText}" 
FontWeight="SemiBold"/>
</StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <ContentControl Grid.Column="1" 
                        Content="{Binding CurrentView.Content}"
                        Margin="24"/>
    </Grid>
</Window>
