<UserControl x:Class="WVLAN.Client.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" 
                Background="{DynamicResource CardBackground}"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Import Config"
                        Command="{Binding ConfigViewModel.ImportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="140"
                        Margin="0,0,12,0"/>
                
                <Button Content="📄 New Profile"
                        Command="{Binding ConfigViewModel.CreateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="140"/>
            </StackPanel>
        </Border>

        <!-- 配置文件列表 -->
        <Border Grid.Row="1" 
                Background="{DynamicResource CardBackground}"
                CornerRadius="12">
            <DataGrid ItemsSource="{Binding ConfigViewModel.Profiles, RelativeSource={RelativeSource AncestorType=Window}}"
                      SelectedItem="{Binding ConfigViewModel.SelectedProfile, RelativeSource={RelativeSource AncestorType=Window}}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding ProfileName}" Width="*"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Interface.Address}" Width="150"/>
                    <DataGridTextColumn Header="Peers" Binding="{Binding Peers.Count}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                    <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Activate" Command="{Binding DataContext.SetActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <MenuItem Header="Edit" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Separator/>
                        <MenuItem Header="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- 编辑弹窗 -->
        <Popup IsOpen="{Binding ConfigViewModel.IsEditing, RelativeSource={RelativeSource AncestorType=Window}}"
               PlacementTarget="{Binding ElementName=ProfilesViewRoot}"
               Placement="Center"
               StaysOpen="True"
               AllowsTransparency="True">
            <Grid>
                <Rectangle Fill="#80000000"/>
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="16"
                        Padding="32"
                        MaxWidth="800"
                        MaxHeight="600"
                        Margin="50">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Edit Profile" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColor}"/>
                            
                            <!-- 在这里添加详细的编辑表单 -->
                            <TextBlock Text="Use the profile editor to modify interface and peer settings."
                                       Opacity="0.7"
                                       Margin="0,16,0,0"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                                <Button Content="Cancel"
                                        Command="{Binding ConfigViewModel.CancelEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="100"
                                        Margin="0,0,12,0"/>
                                <Button Content="Save"
                                        Command="{Binding ConfigViewModel.SaveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        MinWidth="100"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Popup>
    </Grid>
</UserControl>
